# ============================================================
# Rapid Crisis Response — Backend Environment Variables
# Copy to .env and fill in your values for local development
# ============================================================

# ── GCP Core ─────────────────────────────────────────────────
GCP_PROJECT=project-e82fa8f3-3868-42a9-a35
GCP_REGION=us-central1

# ── Gemini API (for crisis intent parsing) ───────────────────
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=

# ── BigQuery (audit logs + staff schedules) ──────────────────
BQ_DATASET=crisis_response

# ── Cloud SQL (real-time staff availability) ─────────────────
# Format: project-id:region:instance-name
CLOUDSQL_INSTANCE=project-e82fa8f3-3868-42a9-a35:us-central1:crisis-db
CLOUDSQL_DB=crisis_response
CLOUDSQL_USER=crisis_admin
CLOUDSQL_PASSWORD=

# ── Firebase / FCM (push notifications) ─────────────────────
# Path to Firebase service account JSON key file
FIREBASE_CREDENTIALS=

# ── Vertex AI Vector Search (protocol retrieval) ─────────────
# Set after running: python infra/seed_protocols.py --create-index
VERTEX_INDEX_ENDPOINT=
VERTEX_DEPLOYED_INDEX_ID=
